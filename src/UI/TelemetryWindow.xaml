<Window x:Class="WinTakMeshtasticPlugin.UI.TelemetryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinTakMeshtasticPlugin.UI"
        mc:Ignorable="d"
        Title="Node Details"
        Width="400" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2D2D30"
        Foreground="#F1F1F1">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0"
                                    Background="{StaticResource TextBoxBackgroundBrush}" CornerRadius="2,2,0,0">
                                <ContentPresenter ContentSource="Header" Margin="10,6"/>
                            </Border>
                            <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource BackgroundBrush}" CornerRadius="0,0,2,2">
                                <ContentPresenter Margin="12"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Node Identity Section -->
                <GroupBox Header="Node Identity">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Long Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Long Name:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LongName, TargetNullValue='Unknown'}" Style="{StaticResource ValueStyle}" FontWeight="Bold"/>

                        <!-- Short Name -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Short Name:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ShortName, TargetNullValue='Unknown'}" Style="{StaticResource ValueStyle}"/>

                        <!-- Hardware Model -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Hardware:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HardwareModel, TargetNullValue='Unknown'}" Style="{StaticResource ValueStyle}"/>

                        <!-- Firmware Version -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Firmware:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FirmwareVersion, TargetNullValue='Unknown'}" Style="{StaticResource ValueStyle}"/>

                        <!-- Node ID -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Node ID:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NodeIdHex}" Style="{StaticResource ValueStyle}" FontFamily="Consolas"/>

                        <!-- Last Heard -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Last Heard:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastHeardFormatted}" Style="{StaticResource ValueStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- Device Telemetry Section -->
                <GroupBox Header="Device Telemetry">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Battery -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Battery:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BatteryDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Voltage -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Voltage:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VoltageDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Uptime -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Uptime:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UptimeDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Channel Utilization -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Channel Util:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ChannelUtilDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Air Util TX -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Air Util TX:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AirUtilTxDisplay}" Style="{StaticResource ValueStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- Environment Section -->
                <GroupBox Header="Environment" x:Name="EnvironmentSection">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Temperature -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Temperature:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TemperatureDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Humidity -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Humidity:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding HumidityDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- Pressure -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Pressure:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PressureDisplay}" Style="{StaticResource ValueStyle}"/>

                        <!-- IAQ (only for BME680/688) -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Air Quality:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"
                                   Visibility="{Binding HasIaq, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding IaqDisplay}" Style="{StaticResource ValueStyle}"
                                   Visibility="{Binding HasIaq, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Close" Click="OnClose" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>

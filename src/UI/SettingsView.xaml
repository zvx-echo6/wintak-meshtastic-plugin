<UserControl x:Class="WinTakMeshtasticPlugin.UI.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WinTakMeshtasticPlugin.UI"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="300"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <!-- Status indicator colors -->
        <SolidColorBrush x:Key="StatusConnected" Color="#4CAF50"/>
        <SolidColorBrush x:Key="StatusDisconnected" Color="#F44336"/>
        <SolidColorBrush x:Key="StatusConnecting" Color="#FFC107"/>

        <!-- Channel team colors -->
        <SolidColorBrush x:Key="TeamCyan" Color="#00BCD4"/>
        <SolidColorBrush x:Key="TeamGreen" Color="#4CAF50"/>
        <SolidColorBrush x:Key="TeamYellow" Color="#FFEB3B"/>
        <SolidColorBrush x:Key="TeamOrange" Color="#FF9800"/>
        <SolidColorBrush x:Key="TeamRed" Color="#F44336"/>
        <SolidColorBrush x:Key="TeamPurple" Color="#9C27B0"/>
        <SolidColorBrush x:Key="TeamWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TeamMagenta" Color="#E91E63"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <!-- Connection Status Section -->
            <GroupBox Header="Connection" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <!-- Status Indicator (CON-02) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="12" Height="12"
                                 Fill="{Binding StatusColor}"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Hostname -->
                    <TextBlock Text="Hostname / IP:" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding IsNotConnected}"/>

                    <!-- Port -->
                    <TextBlock Text="Port:" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             IsEnabled="{Binding IsNotConnected}"
                             Width="80"
                             HorizontalAlignment="Left"/>

                    <!-- Connect/Disconnect Button -->
                    <Button Content="{Binding ConnectButtonText}"
                            Command="{Binding ConnectCommand}"
                            Padding="15,8"
                            HorizontalAlignment="Left"/>

                    <!-- Auto-connect -->
                    <CheckBox Content="Auto-connect on startup"
                              IsChecked="{Binding AutoConnect}"
                              Margin="0,10,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Channel Configuration Section -->
            <GroupBox Header="Channels" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <!-- Outbound Channel Selector (CHN-04) -->
                    <TextBlock Text="Send messages on:" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding TransmitChannels}"
                              SelectedItem="{Binding SelectedOutboundChannel}"
                              Margin="0,0,0,10"
                              IsEnabled="{Binding IsConnected}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="12" Height="12"
                                               Fill="{Binding TeamColorBrush}"
                                               Margin="0,0,8,0"
                                               RadiusX="2" RadiusY="2"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Channel List with Enable/Disable (CHN-03) -->
                    <TextBlock Text="Receive from:" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding Channels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Team Color -->
                                    <Rectangle Grid.Column="0"
                                               Width="12" Height="12"
                                               Fill="{Binding TeamColorBrush}"
                                               Margin="0,0,8,0"
                                               RadiusX="2" RadiusY="2"/>

                                    <!-- Admin Lock Icon (SEC-02) -->
                                    <TextBlock Grid.Column="1"
                                               Text="🔒"
                                               Visibility="{Binding IsAdminVisibility}"
                                               ToolTip="Admin channel - transmit disabled"
                                               Margin="0,0,4,0"/>

                                    <!-- Channel Name -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"/>

                                    <!-- Enable Checkbox -->
                                    <CheckBox Grid.Column="3"
                                              IsChecked="{Binding ReceiveEnabled}"
                                              ToolTip="Enable/disable receive"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </GroupBox>

            <!-- Node Statistics -->
            <GroupBox Header="Statistics" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nodes tracked:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NodeCount}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Channels active:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ChannelCount}" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Advanced Settings -->
            <Expander Header="Advanced" IsExpanded="False">
                <StackPanel Margin="5">
                    <!-- Reconnect Interval -->
                    <TextBlock Text="Reconnect interval (seconds):" Margin="0,5,0,2"/>
                    <TextBox Text="{Binding ReconnectIntervalSeconds}"
                             Width="60" HorizontalAlignment="Left"/>

                    <!-- Stale Timeout -->
                    <TextBlock Text="Stale node timeout (hours):" Margin="0,10,0,2"/>
                    <TextBox Text="{Binding StaleNodeTimeoutHours}"
                             Width="60" HorizontalAlignment="Left"/>

                    <!-- Topology Overlay -->
                    <CheckBox Content="Show topology overlay"
                              IsChecked="{Binding TopologyOverlayEnabled}"
                              Margin="0,10,0,0"/>

                    <!-- Outbound PLI -->
                    <CheckBox Content="Send position to mesh"
                              IsChecked="{Binding OutboundPliEnabled}"
                              Margin="0,10,0,5"/>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding OutboundPliVisibility}">
                        <TextBlock Text="PLI interval:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding OutboundPliIntervalSeconds}"
                                 Width="50" Margin="5,0"/>
                        <TextBlock Text="seconds" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Save Button -->
            <Button Content="Save Settings"
                    Command="{Binding SaveSettingsCommand}"
                    Padding="15,8"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="WinTakMeshtasticPlugin.UI.MeshtasticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinTakMeshtasticPlugin.UI"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="#2D2D30"
             Foreground="#F1F1F1">

    <UserControl.Resources>
        <!-- Converters -->
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#3E3E42"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A0A0A0"/>

        <!-- Status indicator colors -->
        <SolidColorBrush x:Key="ConnectedBrush" Color="#22AA22"/>
        <SolidColorBrush x:Key="DisconnectedBrush" Color="#AA2222"/>
        <SolidColorBrush x:Key="ConnectingBrush" Color="#AAAA22"/>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Foreground" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox Style -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0"
                                    Background="{StaticResource TextBoxBackgroundBrush}" CornerRadius="2,2,0,0">
                                <ContentPresenter ContentSource="Header" Margin="8,4"/>
                            </Border>
                            <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Background="{StaticResource BackgroundBrush}" CornerRadius="0,0,2,2">
                                <ContentPresenter Margin="8"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>

        <!-- ListBoxItem Style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3399FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle Button Style (highlighted when active) -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0094FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bool to Tag converter for toggle button state -->
        <local:BoolToTagConverter x:Key="BoolToTagConverter"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Connection settings -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="*"/>      <!-- Node list / content -->
            <RowDefinition Height="Auto"/>   <!-- Bottom toolbar -->
        </Grid.RowDefinitions>

        <!-- Connection Settings Section -->
        <GroupBox Grid.Row="0" Header="Connection" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Hostname -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"
                         Margin="0,4"/>

                <!-- Port -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="8,4,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}"
                         Margin="0,4"/>

                <!-- Connect/Disconnect buttons -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,4">
                    <Button Content="Connect" Command="{Binding ConnectCommand}" Width="80" Margin="0,0,8,0"/>
                    <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Width="80"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Status Bar -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,4" Margin="0,0,0,8"
                Background="{StaticResource TextBoxBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{StaticResource DisconnectedBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="{StaticResource ConnectedBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Status text -->
                <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" VerticalAlignment="Center"/>

                <!-- Node count -->
                <TextBlock Grid.Column="2" VerticalAlignment="Center">
                    <Run Text="Nodes: "/>
                    <Run Text="{Binding NodeCount, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Node List -->
        <GroupBox Grid.Row="2" Header="Mesh Nodes">
            <ListBox ItemsSource="{Binding Nodes}"
                     SelectedItem="{Binding SelectedNode}"
                     MouseDoubleClick="OnNodeDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding LastHeard, StringFormat='Last: {0:HH:mm:ss}'}" Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <!-- Empty state placeholder -->
                <ListBox.Style>
                    <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NodeCount}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Border Background="{StaticResource TextBoxBackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                <TextBlock Text="No mesh nodes detected yet.&#x0a;&#x0a;Connect to a Meshtastic node to see nearby mesh devices."
                                                           TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" Margin="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>
        </GroupBox>

        <!-- Bottom Toolbar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Topology" Width="70" Margin="0,0,8,0"
                    Command="{Binding ToggleTopologyCommand}"
                    Tag="{Binding TopologyEnabled, Converter={StaticResource BoolToTagConverter}}"
                    Style="{StaticResource ToggleButtonStyle}"
                    ToolTip="Toggle global topology overlay (mesh link lines)"/>
            <Button Content="Settings" Width="70" Margin="0,0,8,0"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="Open plugin settings"/>
            <Button Content="Chat" Width="70" ToolTip="Open mesh chat panel (coming soon)" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
